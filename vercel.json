{
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "clip.air-s.jp"
        }
      ],
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/m/:mapId",
      "destination": "/api/maps?public=1&mapId=:mapId"
    },
    {
      "source": "/embed/:mapId",
      "destination": "/?maps-preview=1&embed=1&mapId=:mapId"
    }
  ]
}
